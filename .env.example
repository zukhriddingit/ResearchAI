# ── LLM Provider ──────────────────────────────────────────────────────────────
# groq (default) | ollama | anthropic
LLM_PROVIDER=groq

# Groq — free tier at https://console.groq.com
# Models: llama-3.1-8b-instant (fast) | llama-3.3-70b-versatile (quality)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama — local, zero cost. Install: https://ollama.ai  then: ollama pull llama3.1
# Uncomment to switch provider to ollama and set LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Anthropic — original provider, kept as fallback
# Set LLM_PROVIDER=anthropic to use
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Weave (W&B) tracing ───────────────────────────────────────────────────────
# Sign up free at https://wandb.ai — traces appear at wandb.ai/<user>/deeppaper/weave
WEAVE_PROJECT=deeppaper
WANDB_API_KEY=

# ── Optional enrichment APIs ──────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
